{
  "manifest_version": 3,
  "name": "Linker",
  "version": "1.0.0",
  "description": "Create personal go/ shortcuts for the websites you use most.",
  "homepage_url": "https://github.com/taichikuji/Linker",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "unlimitedStorage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Linker",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "linker.js"
  }
}
