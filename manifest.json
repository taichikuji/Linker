{
  "manifest_version": 3,
  "name": "Linker",
  "version": "1.4.0",
  "description": "Create personal go/ shortcuts for the websites you use most.",
  "homepage_url": "https://github.com/taichikuji/Linker",
  "icons": {
    "16": "assets/icon_16.png",
    "32": "assets/icon_32.png",
    "48": "assets/icon_48.png",
    "128": "assets/icon_128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "unlimitedStorage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Click to Go/Link",
    "default_icon": {
      "16": "assets/icon_16.png",
      "32": "assets/icon_32.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  }
}